{
  "name": "pytorch-research-engine",
  "version": "1.0.0",
  "description": "Research latest AI papers and generate deep PyTorch assignments each run.",
  "private": true,
  "scripts": {
    "dev:web": "npx serve . --cors -p 3000",
    "dev:proxy": "node scripts/dev-proxy.mjs",
    "dev": "concurrently -k -n web,proxy -c blue,magenta \"npm:dev:web\" \"npm:dev:proxy\"",
    "start": "npm run dev",
    "open": "npx serve . --cors -p 3000 --open",
    "gen-seed": "node scripts/gen-seed.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "serve": "^14.2.3"
  },
  "engines": {
    "node": ">=18"
  }
}
