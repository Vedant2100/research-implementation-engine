# Copy this file to .env and fill in your real key.
# .env is gitignored — never commit real keys.

# NVIDIA NIM (default provider). Get a fresh key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-REPLACE_ME

# Optional: override the provider base URL (rarely needed)
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Port the local dev proxy listens on (frontend talks to this).
PROXY_PORT=3001
